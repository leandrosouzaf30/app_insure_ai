# 1. Configura as variáveis temporárias da CLI para o ambiente local
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1
export FLOCI_URL=http://localhost:4566

# 2. Cria o User Pool simulado
aws cognito-idp create-user-pool \
  --pool-name LocalUserPool \
  --endpoint-url $FLOCI_URL

# 3. Cria o Client ID (use o ID retornado no comando anterior para preencher o --user-pool-id se necessário, ou use o mock)
aws cognito-idp create-user-pool-client \
  --user-pool-id us-east-1_localpoolid \
  --client-name LocalClient \
  --endpoint-url $FLOCI_URL

# 4. Cria o seu usuário de teste para usar na tela de Login do React
aws cognito-idp admin-create-user \
  --user-pool-id us-east-1_localpoolid \
  --username seu@email.com \
  --user-attributes Name=email,Value=seu@email.com \
  --message-action SUPPRESS \
  --endpoint-url $FLOCI_URL

# 5. Define a senha do usuário e já o marca como CONFIRMADO (evita a tela de troca de senha no primeiro login)
aws cognito-idp admin-set-user-password \
  --user-pool-id us-east-1_localpoolid \
  --username seu@email.com \
  --password "SenhaSegura123!" \
  --permanent \
  --endpoint-url $FLOCI_URL